{
  "name": "reinvent-planner",
  "description": "Agent para o projeto re:Invent Community Planner — frontend Vue.js, i18n, dados e issues",
  "tools": [
    "read",
    "write",
    "shell",
    "grep",
    "glob",
    "code",
    "web_fetch",
    "web_search",
    "subagent",
    "knowledge",
    "todo_list",
    "goal",
    "introspect",
    "use_aws",
    "@*"
  ],
  "allowedTools": [
    "read",
    "grep",
    "glob",
    "code",
    "knowledge",
    "introspect",
    "@seats-aero"
  ],
  "hooks": {
    "postToolUse": [
      {
        "matcher": "shell",
        "command": ".kiro/hooks/update-readme-on-feature.sh",
        "timeout_ms": 5000
      }
    ]
  },
  "mcpServers": {
    "seats-aero": {
      "command": "npx",
      "args": ["-y", "seats.aero-mcp-server"],
      "env": {
        "SEATS_API_KEY": "$SEATS_AERO_API_KEY"
      }
    }
  }
}
